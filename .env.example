# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required — from Discord Developer Portal → Your App → Bot
BOT_TOKEN=your_discord_bot_token_here

# Required — your personal Discord user ID (right-click your name → Copy User ID)
MASTER_USER_ID=your_discord_user_id_here

# Optional — speeds up slash command registration during development (guild ID)
DEBUG_GUILD_ID=

# Optional — override the default database file path (defaults to database.db)
DATABASE_PATH=
